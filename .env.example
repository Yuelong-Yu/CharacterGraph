# Image generation — 火山方舟 doubao-seedream
# 申请地址：https://console.volcengine.com/ark/region:ark+cn-beijing/openManagement
IMAGE_API_KEY=your-image-api-key-here
IMAGE_BASE_URL=https://ark.cn-beijing.volces.com/api/plan/v3
IMAGE_MODEL=doubao-seedream-5.0-lite

# Coding LLM — 火山方舟兼容 Anthropic Messages API 的 deepseek-v4-flash
CODING_API_KEY=your-coding-api-key-here
CODING_BASE_URL=https://ark.cn-beijing.volces.com/api/coding
CODING_MODEL=deepseek-v4-flash

# WhatIf feature - PostgreSQL（本地 homebrew 或 docker）
# 本地 homebrew postgres：先 createdb charactergraph，再建 role charactergraph with password 'devpass'
DATABASE_URL=postgresql://charactergraph:devpass@localhost:5432/charactergraph?schema=public

# 生产环境必填：必须与 chronchaos_gpt 的 AUTH_SECRET 完全相同，用于验签共享账号 Cookie。
# 仅服务端使用，不要改成 NEXT_PUBLIC_*。
AUTH_SECRET=
