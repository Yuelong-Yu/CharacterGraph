  "owns": [
    { "owner": "lin_chong", "artifact": "zhangba_shemao", "canon": "romance", "title": "林冲使丈八蛇矛", "desc": "《水浒传》中林冲为东京八十万禁军教头，惯使丈八蛇矛，风雪山神庙手刃陆谦、梁山泊火并王伦皆仗此矛。蛇矛矛头如游蛇蜿蜒、双刃寒利，是禁军教头武艺的标志。", "work": "《水浒传》" },
    { "owner": "lu_zhishen", "artifact": "shuimo_chanzhang", "canon": "romance", "title": "鲁智深持水磨禅杖", "desc": "《水浒传》中鲁智深以六十二斤水磨禅杖为兵器，拳打镇关西、倒拔垂杨柳、大闹野猪林皆携此杖。禅杖一头月牙铲、一头方便铲，重兵器中的僧家法器，与他花和尚身份相映成趣。", "work": "《水浒传》" },
    { "owner": "wu_song", "artifact": "jiedao", "canon": "romance", "title": "武松使戒刀", "desc": "《水浒传》中武松在十字坡得孙二娘所赠两口戒刀，景阳冈打虎用拳、杀潘金莲西门庆用刀、血溅鸳鸯楼夜战蜈蚣岭均携此双刀。戒刀为行者装束中的护法门刃，武松扮行者后即为他的标志兵器。", "work": "《水浒传》" },
    { "owner": "li_kui", "artifact": "banfu", "canon": "romance", "title": "李逵抡板斧", "desc": "《水浒传》中李逵惯使一对板斧，江州劫法场、沂岭杀四虎、大闹东京皆挥双斧。板斧粗重锋利、契合其黑旋风蛮勇冲杀的打法，是李逵莽烈形象的标志。", "work": "《水浒传》" },
    { "owner": "ruan_xiaoqi", "artifact": "yucha", "canon": "romance", "title": "阮小七使渔叉", "desc": "《水浒传》中阮小七为石碣村渔户出身，梁山水军头领，惯使渔叉。智取生辰纲、水战官军、偷御酒等水军行动皆仗此叉。渔叉三齿倒钩、水下灵活，是阮氏三雄水上功夫的标志。", "work": "《水浒传》" }
  ],
